## admixture calculations with ngs admix 

#subsetting to number of reads
for SAMPLEBAM in cat $BAMLIST; do 

samtools view -h -b -L $BEDFILE $BASEDIR'/bwa_bam/'$SAMPLEBAM'_subset.bam' > $BASEDIR'/bwa_bam/'$SAMPLEBAM'_subset_admix.bam' 

done 

# calculate genotype likelihood in beagle format 
$ANGSD -P 16 -GL 2 -out $BASEDIR/results/admix/genolike -nThreads 10 -doGlf 2 -doMajorMinor 1 -SNP_pval 1e-6 -doMaf 1 -minMapQ 20 -minQ 20 -minInd 10 -bam $BASEDIR/sample_lists/admixsubsetbams.txt 

# calc clusters by K and seed
/media/user/16TB/Programs/angsd/angsd/misc/NGSadmix -likes $BASEDIR/results/admix/genolike.beagle.gz -printInfo 1 -K 0 -seed $SEED -P 16 -o $BASEDIR/results/admix/seed$SEED/genolikek0 -minMaf 0.05 


## admixture and inbreeding coeffients with pcangsd
#getting gl file
$ANGSD -P 16 -GL 2 -out $BASEDIR/results/admix/GrayGlf2 -nThreads 10 -doGlf 2 -doMajorMinor 1 -SNP_pval 1e-6 -doMaf 1 -minMapQ 20 -minQ 20 -minInd 10 -bam $BASEDIR/sample_lists/admixsubsetbams.txt  

#activate conda, then
pcangsd --beagle $BASEDIR/results/admix/genolike.beagle.gz --out $BASEDIR/results/admix/pcangsd  ---inbreed-sites --inbreed-samples --admix --selection --threads 32 --sites-save –maf 0.1 --iter 500 

 

 

 
