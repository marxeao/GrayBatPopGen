## Evaluating quality of fastq files

for SAMPLE in `cat $SAMPLELIST`; do 
 
  fastqc $BASEDIR'/raw_fastq/'$SAMPLE$RAWFASTQSUFFIX1 -o $BASEDIR'/fastqc/' 
  fastqc $BASEDIR'/raw_fastq/'$SAMPLE$RAWFASTQSUFFIX2 -o $BASEDIR'/fastqc/' 
 
done 

 

## Removing adapter sequences, if necessary

for SAMPLE in `cat $SAMPLELIST`; do 
  trim_galore --stringency 5 --length 40 --paired $SAMPLE$RAWFASTQSUFFIX1 $SAMPLE$RAWFASTQSUFFIX2 -o adapter_clipped 
done 

 

## indexing reference genome 

bwa index -a bwtsw $REFERENCE $INDEX_PREFIX 
samtools faidx $REFERENCE 
java -Xmx16G -jar picard CreateSequenceDictionary R=$REFERENCE O=$INDEX_PREFIX'.dict' 

 

## map fastqs to reference genome, condense to bam file, then sort and filter for further processing 

bwa mem -t 60 $REF $BASEDIR/adapter_clipped/forwardread.fastq $BASEDIR/adapter_clipped/reverseread.fastq > $BASEDIR/bam/sampleID_bwa.sam 
samtools view -bS -F 4 $BASEDIR/bam/SAMPLEID_bwa.sam > $BASEDIR/bam/SAMPLEID_bwa.bam 
samtools view -@ 60 -h -q 20 $BASEDIR/bam/SAMPLEID_bwa.bam | $SAMTOOLS view -buS | $SAMTOOLS sort -o $BASEDIR/bam/SAMPLEID_bwa_sorted.bam 
# t/@ refers to number of threads
# F means we should only keep true paired reads
# h indicates we want a header
 

## fixing mate information  

for SAMPLEBAM in cat $SAMPLELIST; do java -jar picard FixMateInformation  
I=$BASEDIR'/bam/'$SAMPLEBAM'_bwa_sorted.bam'  
O=$BASEDIR'/bam/'$SAMPLEBAM'_bwa_sorted_fixedmate.bam'  
done 

## adding or replacing read group names

for SAMPLEBAM in cat $SAMPLELIST; do 

java -jar picard AddOrReplaceReadGroups
I=$BASEDIR'/bam/'$SAMPLEBAM'_bwa_sorted_fixedmate.bam'  
O=$BASEDIR'/bam/'$SAMPLEBAM'_bwa_sorted_fixedmate_RG.bam'  
R=$REFERENCE  
RGLB=lib1  
RGPL=illumina  
RGPU=unit1  
RGSM=$SAMPLE  
CREATE_INDEX=True  
VALIDATION_STRINGENCY=LENIENT 

Done 

 
## merging files from different runs

samtools merge -o MYGR-02_S73_merged_bwa_sorted.bam MYGR-02_S73_L005_bwa_sorted.bam MYGR-02_S73_L006_bwa_sorted.bam MYGR-02_S73_L007_bwa_sorted.bam 

 

## deduplicating reads 

for SAMPLEBAM in cat $BAMLIST; do 

java -Xmx60g -jar $PICARD MarkDuplicates I=$BASEDIR'/bam/'$SAMPLEBAM'_bwa_sorted.bam' O=$BASEDIR'/bam/'$SAMPLEBAM'_bwa_'$REFNAME'_sorted_dedup.bam' M=$BASEDIR'/bam/'$SAMPLEBAM'_bwa_'$REFNAME'_sorted_dupstat.txt' VALIDATION_STRINGENCY=SILENT REMOVE_DUPLICATES=true 
  
done 

 

#realigning indels

for SAMPLEBAM in cat $SAMPLELIST; do echo $BASEDIR'/bam/'$SAMPLEBAM'_bwa_NewRef_sorted_fixedmate_RG_dedup.bam' >> $BAMLIST done 

cd $BASEDIR/bam/ 

for SAMPLEBAM in `cat $BAMLIST`; do 

    samtools index $SAMPLEBAM 

Done 

